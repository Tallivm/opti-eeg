{
    "model_name": "EEGNet",
    "optimizer_name": "adam",
    "scheduler_name": "none",
    "depthwise_activation_name": "gelu",
    "separable_activation_name": "gelu",
    "depthwise_pool_name": "max",
    "separable_pool_name": "max",

    "linear_max_norm": 0.5,

    "optimizer_lr": 1e-3,
    "optimizer_momentum": 0.8,
    "optimizer_beta1": 0.9,
    "optimizer_beta2": 0.999,
    "optimizer_eps": 1e-6,
    "optimizer_weight_decay": 1e-3,

    "batch_size": 32,
    "F1": 4,
    "F2": 4,
    "D": 2,
    "depthwise_pool_width": 4,
    "separable_pool_width": 6,
    "temporal_kernel_length": 50,
    "separable_kernel_length": 8,
    "depthwise_dropout_rate": 0.25,
    "separable_dropout_rate": 0.25,
    "depthwise_dropout_name": "simple",
    "separable_dropout_name": "simple",
    "conv_depth_max_norm": 0.99,

    "temporal_momentum": 0.01,
    "depthwise_momentum": 0.01,
    "separable_momentum": 0.01,
    "temporal_eps": 1e-3,
    "depthwise_eps": 1e-3,
    "separable_eps": 1e-3,
    "temporal_affine": true,
    "depthwise_affine": true,
    "separable_affine": true
}
